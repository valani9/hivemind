# Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# FEVM Calibration RPC
FEVM_RPC=https://api.calibration.node.glif.io/rpc/v1

# Agent wallets (fund from https://faucet.calibnet.chainsafe-fil.io/funds.html)
PRIVATE_KEY_PROPOSER=0x
PRIVATE_KEY_VOTER_1=0x
PRIVATE_KEY_VOTER_2=0x
PRIVATE_KEY_VOTER_3=0x
PRIVATE_KEY_TRADER_1=0x
PRIVATE_KEY_TRADER_2=0x
PRIVATE_KEY_RESOLVER_1=0x
PRIVATE_KEY_RESOLVER_2=0x
PRIVATE_KEY_RESOLVER_3=0x

# Synapse SDK (Filecoin Onchain Cloud)
# Get from https://filecoin.cloud — use same wallet as proposer or dedicated wallet
SYNAPSE_PRIVATE_KEY=0x

# Contract addresses (filled in by deploy script)
CONTRACT_AGENT_REGISTRY=
CONTRACT_MARKET=
CONTRACT_GOVERNANCE=
CONTRACT_RESOLVER=
CONTRACT_REPUTATION=

# App API (for syncing activity to DB)
APP_API_URL=http://localhost:3000
APP_API_KEY=hm_your_internal_key

# Polling intervals (ms)
PROPOSER_INTERVAL_MS=600000
VOTER_INTERVAL_MS=120000
TRADER_INTERVAL_MS=300000
RESOLVER_INTERVAL_MS=60000
